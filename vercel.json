{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "regions": ["iad1"],
  "redirects": [
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/news", "destination": "/news", "permanent": true },
    { "source": "/upcoming-events", "destination": "/events", "permanent": true },
    { "source": "/upcoming-events-2", "destination": "/events", "permanent": true },
    { "source": "/past-events", "destination": "/events", "permanent": true },
    { "source": "/calendar", "destination": "/events", "permanent": true },
    { "source": "/2025-races-calendar", "destination": "/events", "permanent": true },
    { "source": "/about", "destination": "/about", "permanent": true },
    { "source": "/sponsors", "destination": "/sponsors", "permanent": true },
    { "source": "/rules-forms", "destination": "/drivers", "permanent": true },
    { "source": "/driver-information-form", "destination": "/drivers", "permanent": true },
    { "source": "/official-entry-form-usra-modifieds", "destination": "/drivers", "permanent": true },
    { "source": "/official-entry-form-stocks-x-mods", "destination": "/drivers", "permanent": true },
    { "source": "/fan-registration-form", "destination": "/about", "permanent": true },
    { "source": "/shout-out-request-form", "destination": "/about", "permanent": true },
    { "source": "/faq", "destination": "/plan-your-visit", "permanent": true },
    { "source": "/food-concessions", "destination": "/plan-your-visit", "permanent": true },
    { "source": "/suites", "destination": "/plan-your-visit", "permanent": true },
    { "source": "/points", "destination": "/points", "permanent": true },
    { "source": "/points-2", "destination": "/points", "permanent": true },
    { "source": "/points-3", "destination": "/points", "permanent": true },
    { "source": "/results", "destination": "/results", "permanent": true },
    { "source": "/race-results", "destination": "/results", "permanent": true },
    { "source": "/photos", "destination": "/news", "permanent": true },
    { "source": "/videos", "destination": "/news", "permanent": true },
    { "source": "/2025-wild-west-shootout", "destination": "/events/archive/wild-west-shootout", "permanent": true },
    { "source": "/fall-nationals", "destination": "/events", "permanent": true },
    { "source": "/design", "destination": "/", "permanent": true },
    { "source": "/sample-page", "destination": "/", "permanent": true },
    { "source": "/test", "destination": "/", "permanent": true },
    { "source": "/driver-survey", "destination": "/drivers", "permanent": true },
    { "source": "/fan-survey", "destination": "/about", "permanent": true }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/sync-all",
      "schedule": "59 5 * * *"
    },
    {
      "path": "/api/sync-all",
      "schedule": "0 12 * * *"
    }
  ]
}
